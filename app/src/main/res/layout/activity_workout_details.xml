<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBackground">

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/appBackground">

    <!-- ANTRAŠTĖ -->

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="24dp"
        app:backgroundTint="@color/navItemInactive"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon_arrow_back" />

    <TextView
        android:id="@+id/tvWorkoutType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Ėjimas"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/guideline5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fabBack" />

    <TextView
        android:id="@+id/tv_activity_workout_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Vasario 25, 2025"
        android:textColor="@color/textMuted"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvWorkoutType" />


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.20" />

    <!-- Žemėlapio BLOKAS -->
    <ImageView
        android:id="@+id/imgMapPreview"
        android:layout_width="0dp"
        android:layout_height="300dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@+id/guideline5" />

    <!-- Duomenų BLOKAS -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardWorkout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/appBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgMapPreview">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTimerDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@android:color/white"
                android:textSize="48sp"
                android:textStyle="bold" />


            <LinearLayout
                android:id="@+id/statsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Eilutė 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Kalorijos -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_margin="4dp"
                        android:layout_weight="1"
                        android:padding="12dp"
                        app:cardBackgroundColor="@color/navItemInactive"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/workout_Calories_detail_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kcal"
                                android:textColor="@android:color/secondary_text_dark"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvWorkout_detail_Calories"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@android:color/white"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Atstumas -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_margin="4dp"
                        android:layout_weight="1"
                        android:padding="12dp"
                        app:cardBackgroundColor="@color/navItemInactive"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_workout_Vid_Calories_detail_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vid. kcal (kcal/km)"
                                android:textColor="@android:color/secondary_text_dark"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_workout_detail_vidKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@android:color/white"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <!-- Eilutė 2? -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Atstumas -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_margin="4dp"
                        android:layout_weight="1"
                        android:padding="12dp"
                        app:cardBackgroundColor="@color/navItemInactive"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_workout_detail_Distance_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Atstumas (km)"
                                android:textColor="@android:color/secondary_text_dark"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_workout_detail_Distance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0"
                                android:textColor="@android:color/white"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>


                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_margin="4dp"
                        android:layout_weight="1"
                        android:padding="12dp"
                        app:cardBackgroundColor="@color/navItemInactive"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_workout_detail_StepLength_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vid. žingsnio ilgis (cm)"
                                android:textColor="@android:color/secondary_text_dark"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_workout_detail_StepLength"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="84"
                                android:textColor="@android:color/white"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <!-- 3 eilutė -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Žingsniai -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_margin="4dp"
                        android:layout_weight="1"
                        android:padding="12dp"
                        app:cardBackgroundColor="@color/navItemInactive"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_workout_detail_Steps_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Žingsniai"
                                android:textColor="@android:color/secondary_text_dark"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/workout_Steps"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@android:color/white"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>


                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_margin="4dp"
                        android:layout_weight="1"
                        android:padding="12dp"
                        app:cardBackgroundColor="@color/navItemInactive"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_workout_detail_VidSteps_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Žingsnių dažnis (min)"
                                android:textColor="@android:color/secondary_text_dark"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_workout_detail_VidSteps"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="137"
                                android:textColor="@android:color/white"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <!-- 4 eilutė -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Tempas-->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_margin="4dp"
                        android:layout_weight="1"
                        android:padding="12dp"
                        app:cardBackgroundColor="@color/navItemInactive"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_workout_detail_Speed_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tempas (km/h)"
                                android:textColor="@android:color/secondary_text_dark"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_workout_detail_Speed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0"
                                android:textColor="@android:color/white"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>


                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_margin="4dp"
                        android:layout_weight="1"
                        android:padding="12dp"
                        app:cardBackgroundColor="@color/navItemInactive"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_workout_detail_VidSpeed_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vid. tempas (min/km)"
                                android:textColor="@android:color/secondary_text_dark"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_workout_detail_VidSpeed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6:12"
                                android:textColor="@android:color/white"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>


            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>